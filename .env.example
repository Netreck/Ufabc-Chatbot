APP_NAME=UFABC Chatbot API
APP_ENV=dev
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
DATABASE_URL=sqlite+aiosqlite:///./data/ufabc_chatbot.db
FEED_STORAGE_DIR=./data/feed_files
FEED_STORAGE_BACKEND=local
SEAWEED_S3_ENDPOINT=http://localhost:8333
SEAWEED_S3_ACCESS_KEY=seaweed_local_access
SEAWEED_S3_SECRET_KEY=seaweed_local_secret
SEAWEED_S3_REGION=us-east-1
SEAWEED_S3_BUCKET=ufabc-feed
SEAWEED_S3_SECURE=false
SEAWEED_S3_CREATE_BUCKET_IF_MISSING=true
MAX_FEED_FILE_SIZE_MB=25

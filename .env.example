# ── App ──
APP_NAME=UFABC Chatbot API
APP_ENV=dev

# ── OpenAI ──
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Database (Postgres — used in docker-compose) ──
POSTGRES_DB=ufabc_chatbot
POSTGRES_USER=ufabc
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5433

# ── Database (local dev — SQLite, ignored when running docker) ──
DATABASE_URL=sqlite+aiosqlite:///./data/ufabc_chatbot.db

# ── Feed Storage ──
FEED_STORAGE_BACKEND=local
FEED_STORAGE_DIR=./data/feed_files
MAX_FEED_FILE_SIZE_MB=25

# ── SeaweedFS S3 (used in docker-compose) ──
SEAWEED_S3_ENDPOINT=http://localhost:8333
SEAWEED_S3_ACCESS_KEY=seaweed_local_access
SEAWEED_S3_SECRET_KEY=seaweed_local_secret
SEAWEED_S3_REGION=us-east-1
SEAWEED_S3_BUCKET=ufabc-feed
SEAWEED_S3_PORT=8333

# ── Auth / JWT ──
JWT_SECRET_KEY=change-me-run-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Admin Seed (created on first startup if set) ──
ADMIN_EMAIL=admin@ufabc.edu.br
ADMIN_PASSWORD=change_me_strong_password

# ── Ports ──
BACKEND_PORT=8000
FRONTEND_PORT=8080
